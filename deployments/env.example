# =============================================================================
# OpenHole — environment template
# Copy to .env and fill in values:
#   cp env.example .env
# Never commit .env (contains secrets).
# =============================================================================

# -----------------------------------------------------------------------------
# YOUR VPS (for DNS setup in Cloudflare — not read by the app)
# -----------------------------------------------------------------------------
VPS_PUBLIC_IP=

# -----------------------------------------------------------------------------
# Cloudflare — required for *.ophl.link wildcard TLS (DNS-01)
# Create: Cloudflare → My Profile → API Tokens → Edit zone DNS
# Zones: openhole.dev + ophl.link | Permission: Zone → DNS → Edit
# -----------------------------------------------------------------------------
CLOUDFLARE_API_TOKEN=

# -----------------------------------------------------------------------------
# Caddy / Let's Encrypt
# -----------------------------------------------------------------------------
CADDY_ACME_EMAIL=admin@openhole.dev

# -----------------------------------------------------------------------------
# Tunnel server (openhole-server)
# -----------------------------------------------------------------------------
PUBLIC_TUNNEL_DOMAIN=ophl.link
TUNNEL_ENDPOINT_HOST=tunnel.openhole.dev
SERVER_PORT=8080
PUBLIC_URL_SCHEME=https
# Must be true when behind Caddy (Docker default). Set false if exposing :8080 directly.
TRUST_PROXY_HEADERS=true

# Limits
MAX_BODY_BYTES=10485760
REQUEST_TIMEOUT_SECONDS=30
MAX_CONCURRENT_REQUESTS_PER_TUNNEL=25
MAX_TUNNELS_PER_IP=3
MAX_REGISTRATIONS_PER_IP_PER_MINUTE=5
MAX_PUBLIC_REQUESTS_PER_IP_PER_MINUTE=120
SUBDOMAIN_HOLD_SECONDS=30

# Abuse (comma-separated, no spaces required)
BLOCKED_IPS=
BLOCKED_SUBDOMAINS_EXTRA=

# -----------------------------------------------------------------------------
# Landing page (website / Next.js)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_TUNNEL_DOMAIN=ophl.link
