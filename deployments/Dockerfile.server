FROM golang:1.23-alpine AS builder
ENV GOTOOLCHAIN=auto
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -ldflags="-s -w" -o /openhole-server ./cmd/openhole-server

FROM alpine:3.20
RUN apk add --no-cache ca-certificates wget
COPY --from=builder /openhole-server /usr/local/bin/openhole-server
EXPOSE 8080
CMD ["openhole-server"]
